<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.k.pmpstudy.CopyAbbreviatedGitRevision</id>

    <name>CopyAbbreviatedGitRevision</name>

    <vendor url="https://www.yourcompany.com">CopyAbbreviatedGitRevision</vendor>

    <description><![CDATA[
        Adds a context menu action to the Git Log view that copies the abbreviated
        revision hash of the selected commit(s). The abbreviation style is configurable:
        <ul>
          <li>Unique shortest (<code>git rev-parse --short</code>) &mdash; default</li>
          <li>Fixed length (user-specified length)</li>
        </ul>
        ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
                serviceImplementation="com.k.pmpstudy.CopyAbbreviatedGitRevisionSettings"/>
        <applicationConfigurable
                parentId="tools"
                id="com.k.pmpstudy.CopyAbbreviatedGitRevisionConfigurable"
                displayName="Copy Abbreviated Git Revision"
                instance="com.k.pmpstudy.CopyAbbreviatedGitRevisionConfigurable"/>
    </extensions>

    <actions>
        <action id="com.k.pmpstudy.CopyAbbreviatedGitRevisionAction"
                class="com.k.pmpstudy.CopyAbbreviatedGitRevisionAction"
                text="Copy Abbreviated Revision Number"
                description="Copy abbreviated Git revision hash of the selected commit(s)">
            <add-to-group group-id="Vcs.Log.ContextMenu"
                          anchor="after"
                          relative-to-action="Vcs.CopyRevisionNumberAction"/>
        </action>
    </actions>

</idea-plugin>
